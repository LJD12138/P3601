static void vFwdgt_ResetPrintf(const char *str, ...)
{
    char log_buf[128] = {0};
    va_list args;

    va_start(args, str);
    vsnprintf(log_buf, sizeof(log_buf), str, args);
    va_end(args);

    #if(boardPRINT_IFACE)
    sMyPrint("%s", log_buf);
    #endif

    #if(printSEGGER)
    SEGGER_RTT_printf(0, "%s", log_buf);
    #endif
}


void vFwdgt_EnterLowPower(void)
{
	vFwdgt_Reload();
  /* configure FWDGT counter clock: 40KHz(IRC40K)  / 256 = 0.156 KHz */
  fwdgt_config(0xfff,FWDGT_PSC_DIV256);				 //t = 26S
	
  fwdgt_write_disable();
  /* After 1.6 seconds to generate a reset */
  fwdgt_enable();
}


